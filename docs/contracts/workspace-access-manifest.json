{
  "schema": "simplicio.workspace-access-manifest/v1",
  "scopes": ["crates/codegen/simplicio-runtime-client", "crates/codegen/xai-grok-workspace/src/file_system"],
  "rules": [
    {
      "path": "crates/codegen/simplicio-runtime-client/src/**",
      "kind": "process",
      "classification": "runtime-governed",
      "owner": "simplicio-runtime-client",
      "rationale": "The client launches only the negotiated Runtime MCP boundary."
    },
    {
      "path": "crates/codegen/simplicio-runtime-client/src/**",
      "kind": "filesystem",
      "classification": "test-fixture",
      "owner": "simplicio-runtime-client",
      "rationale": "Fixture setup is contained in cfg(test) code and is never a production path."
    },
    {
      "path": "crates/codegen/xai-grok-workspace/src/file_system/*status.rs",
      "kind": "process",
      "classification": "bootstrap-allowlisted",
      "owner": "workspace-bootstrap",
      "rationale": "Git/JJ status is bootstrap metadata and cannot read workspace content through a fallback."
    },
    {
      "path": "crates/codegen/xai-grok-workspace/src/file_system/**",
      "kind": "*",
      "classification": "violation",
      "owner": "runtime-wiring",
      "rationale": "Existing direct workspace access remains an explicit migration finding until #49 wiring lands."
    },
    {
      "path": "crates/codegen/**/tests/**",
      "kind": "*",
      "classification": "test-fixture",
      "owner": "test-suite",
      "rationale": "Test fixture I/O is not a production workspace path."
    }
  ]
}
